  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug unit tests in library 'diffutilslib'",
      "cargo": {
        "args": ["test", "--no-run", "--lib", "--package=diffutils"],
        "filter": {
          "name": "diffutilslib",
          "kind": "lib"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug executable 'diffutils'",
      "cargo": {
        "args": ["build", "--bin=diffutils", "--package=diffutils"],
        "filter": {
          "name": "diffutils",
          "kind": "bin"
        }
      },
      // "args": ["sdiff", "fruits_old.txt","--", "fruits_new.txt", "-v"],
      "args": ["sdiff", "old.txt", "new.txtx"],
      // "args": ["sdiff"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug unit tests in executable 'diffutils'",
      "cargo": {
        "args": ["test", "--no-run", "--bin=diffutils", "--package=diffutils"],
        "filter": {
          "name": "diffutils",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug integration test 'integration'",
      "cargo": {
        "args": [
          "test",
          "--no-run",
          "--test=integration",
          "--package=diffutils"
        ],
        "filter": {
          "name": "integration",
          "kind": "test"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    }
  ]
}
